<div{{ attributes }}>


    {% if app.environment == 'dev' %}
        <a class="btn btn-warning" href="{{ path('oauth_providers') }}">Configure OAuth</a>
    {% endif %}
    <hr />

    {% for clientKey in this.clientKeys %}
        <a
            class="{{ this.buttonClass }}"
            href="{{ path('auth_oauth_connect', {provider: clientKey}) }}"
        >
            {{ ux_icon(clientKey, { class: 'me-1' }) }}
            Continue with {{ clientKey|title }}
        </a>
    {% endfor %}

    {% if this.missingProviders %}
        <div class="mt-3 text-muted small">
            Missing providers: {{ this.missingProviders|join(', ') }}
        </div>
    {% endif %}

