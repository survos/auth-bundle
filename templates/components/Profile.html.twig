<div {{ attributes }} class="auth-profile">
    <h2>{{ ux_icon('user', {class: 'me-2'}) }} Profile</h2>

    <div class="card p-3">
        <div><strong>Email:</strong> {{ app.user ? app.user.userIdentifier : 'n/a' }}</div>
    </div>

    <div class="mt-3">
        <a class="btn btn-secondary" href="/logout">Logout</a>
    </div>
</div>
