{
    "name": "survos/auth-bundle",
    "description": "Helper commands and classes for symfony security",
    "license": "MIT",
    "authors": [
        {
            "name": "Tac Tacelosky",
            "email": "tacman@gmail.com"
        }
    ],
    "type": "symfony-bundle",
    "require": {
        "php": "^8.4",
        "doctrine/orm": "^3.3",
        "knpuniversity/oauth2-client-bundle": "^2.20",
        "symfony/config": "^8.0",
        "symfony/console": "^8.0",
        "symfony/dependency-injection": "^8.0",
        "symfony/http-kernel": "^8.0",
        "symfony/options-resolver": "^8.0",
        "symfony/password-hasher": "^8.0",
        "symfony/security-bundle": "^8.0",
        "symfony/ux-twig-component": "^2.8",
        "symfony/yaml": "^8.0",
        "twig/twig": "^3.4",
        "symfony/ux-icons": "^2.34"
    },
    "require-dev": {
        "roave/security-advisories": "dev-latest",
        "phpstan/phpstan": "^2.0",
        "doctrine/doctrine-bundle": "^3.0",
        "stevenmaguire/oauth2-dropbox": "^3.1"
    },
    "autoload": {
        "psr-4": {
            "Survos\\AuthBundle\\": "src/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "2.1-dev"
        }
    },
    "config": {
    },
    "prefer-stable": true
}
